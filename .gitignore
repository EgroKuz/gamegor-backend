```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Django specific
*.sqlite3
*.log
local_settings.py

# Dependencies
venv/
.venv/
.env
.env.local
.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Build and distribution artifacts
dist/
build/
*.egg-info/

# Temporary files
*.tmp
*.temp
```